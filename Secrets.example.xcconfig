// Copy this file to `Secrets.xcconfig` (gitignored) and fill in the real values
// from the existing web-app Supabase project. Wired into the build in Phase 6.
//
// Note: xcconfig values cannot contain "//" (it's a comment). The Supabase URL's
// scheme separator is escaped at read time, so store the host without "https://"
// and prepend the scheme in code, OR use the SUPABASE_URL_SCHEME split below.

SUPABASE_URL = https:/$()/your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here

// Google OAuth *iOS* client ID for the Gmail scan feature (Planner -> Scan Gmail).
// Create one in a Google Cloud project with the Gmail API enabled; no client
// secret is used (PKCE public client). See docs/GOOGLE_SETUP.md. Leave unset to
// keep Gmail scanning disabled (the app builds and runs fine without it).
GOOGLE_OAUTH_CLIENT_ID = your-ios-client-id.apps.googleusercontent.com
